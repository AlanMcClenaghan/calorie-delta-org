    <environments>Default</environments>
    <formulas>
        <name>calculateTargetCalories</name>
        <dataType>Number</dataType>
        <expression>CASE(
TEXT($Record.Goal_Type__c),
&quot;Lose Weight - Fast&quot;, $Record.Total_Daily_Energy_Expenditure_TDEE__c - 1000,
&quot;Lose Weight - Moderate&quot;, $Record.Total_Daily_Energy_Expenditure_TDEE__c - 500,
&quot;Lose Weight - Slow&quot;, $Record.Total_Daily_Energy_Expenditure_TDEE__c - 250,
&quot;Maintain Weight&quot;, $Record.Total_Daily_Energy_Expenditure_TDEE__c,
&quot;Gain Weight&quot;, $Record.Total_Daily_Energy_Expenditure_TDEE__c + 500,
$Record.Total_Daily_Energy_Expenditure_TDEE__c
)</expression>
        <scale>0</scale>
    </formulas>
    <interviewLabel>Update Target Calories {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update Target Calories</label>
    <processMetadataValues>
